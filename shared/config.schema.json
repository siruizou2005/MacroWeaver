          "type": "string"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        },
        "use_cache": {
          "default": true,
          "title": "Use Cache",
          "type": "boolean"
        },
        "max_concurrency": {
          "default": 5,
          "title": "Max Concurrency",
          "type": "integer"
        },
        "question_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Question Template"
        }
      },
      "title": "PolicyConfig",
      "type": "object"
    },
    "SchedulerConfig": {
      "properties": {
        "granularity": {
          "default": "round",
          "title": "Granularity",
          "type": "string"
        },
        "reflect_every": {
          "default": 4,
          "title": "Reflect Every",
          "type": "integer"
        }
      },
      "title": "SchedulerConfig",
      "type": "object"
    }
  },
  "properties": {
