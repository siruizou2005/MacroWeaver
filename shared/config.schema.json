          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agents"
    },
    "layers": {
      "$ref": "#/$defs/LayerConfig"
    },
    "scheduler": {
      "$ref": "#/$defs/SchedulerConfig"
    },
    "policy": {
      "$ref": "#/$defs/PolicyConfig"
    }
  },
  "required": [
    "market"
  ],
  "title": "Config",
  "type": "object"
}